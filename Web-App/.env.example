VITE_CONTENT_NFT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
VITE_CHAIN_ID=31337
VITE_ANVIL_RPC_URL=http://127.0.0.1:8545
VITE_IPFS_UPLOAD_PROVIDER=local
VITE_IPFS_GATEWAY_BASE=http://127.0.0.1:8080/ipfs
LOCAL_IPFS_API_URL=http://127.0.0.1:5001
# Optional: override the public IPFS gateway used for reads.
# VITE_IPFS_GATEWAY_BASE=https://gateway.pinata.cloud/ipfs
# Optional: override the upload-signing endpoint if your API is hosted elsewhere.
# VITE_PINATA_PRESIGN_ENDPOINT=https://your-app.vercel.app/api/pinata/presign
# Optional local development override. Keep metadata and preview uploads public.
# Set content to private only after you add a private download/access-link endpoint.
# VITE_PINATA_CONTENT_NETWORK=public

# Optional: configure a public transaction explorer base if you deploy to a public chain.
# VITE_EXPLORER_TX_BASE=https://your-explorer-base/tx
# Demo only: VITE_* variables are exposed to every browser user in a public deployment.
# Do not put a long-lived Pinata admin JWT here for a real online launch.
# Prefer a server-side upload signer or serverless proxy instead.
# VITE_PINATA_JWT=demo_only_pinata_jwt
# Server-side only for Vercel/Cloudflare Functions:
# Local Vite dev server can also read this unprefixed value for /api/pinata/presign.
# PINATA_JWT=your_server_side_pinata_jwt
# PINATA_MAX_FILE_BYTES=104857600
# PINATA_PRESIGN_TTL=60
# PINATA_CONTENT_NETWORK=public
# UPLOAD_ALLOWED_ORIGINS=https://your-app.vercel.app
# Optional public-chain values:
# VITE_CHAIN_ID=99911155111
# VITE_TENDERLY_RPC_URL=https://virtual.sepolia.eu.rpc.tenderly.co/your-rpc-id
# VITE_IPFS_UPLOAD_PROVIDER=pinata
# VITE_PINATA_KEY=your_pinata_key
# VITE_PINATA_SECRET=your_pinata_secret
